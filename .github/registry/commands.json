{
  "$schema": "./schema/commands.schema.json",
  "version": 1,
  "commands": [
    {
      "id": "cargo-check-scoped",
      "tier": "fast",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Type-check one crate",
      "command": "cargo check -p toaster --lib",
      "duration": "~60s cold, <10s warm"
    },
    {
      "id": "cargo-clippy-scoped",
      "tier": "fast",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Lint one crate",
      "command": "cargo clippy -p toaster --lib"
    },
    {
      "id": "cargo-test-single",
      "tier": "fast",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Run a single test",
      "command": "cargo test -p toaster --lib <test_name>"
    },
    {
      "id": "cargo-test-module",
      "tier": "fast",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Run one module's tests",
      "command": "cargo test -p toaster --lib <module>::"
    },
    {
      "id": "cargo-test-stdout",
      "tier": "fast",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Single test with stdout",
      "command": "cargo test test_filter_filler_words -- --nocapture"
    },
    {
      "id": "npm-lint-scoped",
      "tier": "fast",
      "shell": "any",
      "purpose": "Scoped eslint",
      "command": "npm run lint -- src/components/editor/"
    },
    {
      "id": "check-file-sizes",
      "tier": "fast",
      "shell": "any",
      "purpose": "800-line cap gate",
      "command": "bun run check:file-sizes"
    },
    {
      "id": "check-translations",
      "tier": "fast",
      "shell": "any",
      "purpose": "i18n parity (20 locales)",
      "command": "bun scripts/check-translations.ts"
    },
    {
      "id": "bun-install",
      "tier": "full",
      "shell": "any",
      "purpose": "Install frontend deps",
      "command": "bun install --frozen-lockfile"
    },
    {
      "id": "cargo-check-full",
      "tier": "full",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Full workspace type-check",
      "command": "cargo check",
      "duration": "2–10 min cold"
    },
    {
      "id": "cargo-clippy-full",
      "tier": "full",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Full workspace lint",
      "command": "cargo clippy",
      "duration": "2–10 min cold"
    },
    {
      "id": "cargo-test-full",
      "tier": "full",
      "shell": "any",
      "cwd": "src-tauri",
      "purpose": "Full unit + integration tests",
      "command": "cargo test"
    },
    {
      "id": "npm-build",
      "tier": "full",
      "shell": "any",
      "purpose": "Vite production build",
      "command": "npm run build"
    },
    {
      "id": "npm-lint-full",
      "tier": "full",
      "shell": "any",
      "purpose": "Full eslint pass",
      "command": "npm run lint"
    },
    {
      "id": "tauri-dev",
      "tier": "live",
      "shell": "any",
      "purpose": "Full dev app",
      "command": "cargo tauri dev",
      "duration": "First run compiles ~689 crates"
    },
    {
      "id": "launch-toaster-monitored",
      "tier": "live",
      "shell": "pwsh",
      "purpose": "Monitored live-app verification (required for audio/caption/preview/export fixes)",
      "command": "pwsh scripts/launch-toaster-monitored.ps1 -Duration 5m",
      "when": "audio / caption / preview / export fix"
    },
    {
      "id": "eval-edit-quality",
      "tier": "live",
      "shell": "pwsh",
      "purpose": "Precision eval (fixture-based)",
      "command": "pwsh scripts/eval/eval-edit-quality.ps1"
    },
    {
      "id": "eval-audio-boundary",
      "tier": "live",
      "shell": "pwsh",
      "purpose": "Splice seam quality",
      "command": "pwsh scripts/eval/eval-audio-boundary.ps1"
    },
    {
      "id": "eval-multi-backend-parity",
      "tier": "live",
      "shell": "pwsh",
      "purpose": "ASR backend parity",
      "command": "pwsh scripts/eval/eval-multi-backend-parity.ps1"
    }
  ]
}
